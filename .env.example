###########################
# .env file used for development purposes
# Environment variables for production are defined in the GitLab CI/CD variables
###########################

# Discord Bot Credentials
BOT_TOKEN=
CLIENT_ID=
GUILD_ID= # Optional: For development/testing guild commands
OWNER_ID=

# Bot Settings
DEV_MODE= # YES/NO
LOG_LEVEL= # set to debug for more verbose logging

# Other Credentials (if used by bot features)
EMAIL_USER=
EMAIL_PASS=
GITLAB_EMAIL=

# Lavalink Configuration
LAVALINK_HOST=lavalink # Should match the service name in docker-compose.yml
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass # CHANGE THIS!
LAVALINK_NODE_ID=mainNode
LAVALINK_SECURE=false # Set to true if using SSL

# Lavalink Optional Features (YouTube POT - see https://github.com/iv-org/youtube-trusted-session-generator)
LAVALINK_YOUTUBE_POT_TOKEN=
LAVALINK_YOUTUBE_POT_VISITORDATA=

# Lavalink Optional Features (Spotify - requires client ID/secret).
# These same credentials enable Spotify-first catalog autoplay (related artists + top tracks); MusicBrainz fills gaps when SPOTIFY_* is unset or Spotify returns nothing.
LAVALINK_SPOTIFY_ENABLED=true
LAVALINK_SPOTIFY_CLIENT_ID=
LAVALINK_SPOTIFY_CLIENT_SECRET=
# Optional override for autoplay only (otherwise Lavalink Spotify vars are used):
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
LAVALINK_SPOTIFY_COUNTRY_CODE=US
LAVALINK_SPOTIFY_PLAYLIST_LOAD_LIMIT=6
LAVALINK_SPOTIFY_ALBUM_LOAD_LIMIT=6

# Autoplay: MusicBrainz fallback when Spotify returns nothing (https://musicbrainz.org/doc/MusicBrainz_API — ~1 req/s, User-Agent required).
# Requires MUSICBRAINZ_CONTACT or MUSICBRAINZ_CONTACT_URL. docker-compose defaults MUSICBRAINZ_SIMILAR to off — set to on (or true) to enable when contact is set.
# MUSICBRAINZ_CONTACT=you@example.com
# MUSICBRAINZ_CONTACT_URL=https://your-site.example
# MUSICBRAINZ_SIMILAR=on
