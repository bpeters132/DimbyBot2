################################################################################
# DimbyBot2 — Next.js dashboard (`src/web/`) environment reference
################################################################################
#
# How to use
# -----------
# - Local Next dev: copy this file to `.env.local` in **this directory** (`src/web/`)
#   and fill in values. Next loads `.env`, `.env.local`, `.env.development.local`, etc.
#   from `src/web/` when you run `yarn dev` here or `yarn dev:web` from the repo root.
# - Never commit real secrets. `.env.local` is gitignored by convention.
#
# Production / Docker (`dimbybot-web` in `docker-compose.dashboard.yml`) injects the
# same variable **names** from the host project `.env` (see repo root `.env.example`
# and `.github/workflows/deploy.yml`). The web image does not bake secrets at build time.
#
# Cross-reference: repo root `.env.example` documents the full stack (bot, Lavalink,
# Postgres, image tags). This file lists only what the **dashboard** process reads.
#
################################################################################
# Database (Prisma — `src/lib/webPrisma.ts`, imported as `@/lib/prisma`)
################################################################################
#
# Required in production (`NODE_ENV=production`). URL must be reachable from the
# process that runs Next (localhost when dev on host; `postgres-db` only inside Compose).
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
#
# Optional dev-only: if unset in development, you may set:
# ALLOW_DEV_DATABASE_FALLBACK=true
# …to use a built-in local default (see root `.env.example`). Not for production.
#
# DATABASE_URL=
# ALLOW_DEV_DATABASE_FALLBACK=

################################################################################
# Better Auth + Discord OAuth (`src/shared/auth-base-config.ts`, `src/web/auth.ts`)
################################################################################
#
# BETTER_AUTH_SECRET — signing / encryption; MUST match the **bot** container exactly.
# BETTER_AUTH_URL — public origin users open (no path): cookies, OAuth, trustedOrigins.
#   Production example: https://dashboard.example.com
#   Local dev:          http://localhost:3000
#
# Discord Developer Portal → OAuth2 → Redirects must include **exactly**:
#   {BETTER_AUTH_URL}/api/auth/callback/discord
# e.g. https://dashboard.example.com/api/auth/callback/discord
#
# DISCORD_CLIENT_SECRET — Discord application OAuth2 client secret.
# CLIENT_ID — same Discord application’s Application ID (used for invite links, etc.).
#
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
DISCORD_CLIENT_SECRET=
CLIENT_ID=

################################################################################
# Better Auth — optional public URL for the auth client (rare)
################################################################################
#
# The browser `createAuthClient()` (better-auth/react) resolves the API base from
# `NEXT_PUBLIC_*` vars when set. Leave unset for normal same-origin `/api/auth`.
#
# NEXT_PUBLIC_BETTER_AUTH_URL=
# NEXT_PUBLIC_AUTH_URL=
# NEXTAUTH_URL=

################################################################################
# Bot HTTP API — server-side proxy (`src/shared/bot-api-origin.ts`)
################################################################################
#
# API_PROXY_TARGET — origin **only** (scheme + host + port, no path, no credentials):
#   - Local dev (Next on host, bot on host): http://localhost:3001
#   - Docker `dimbybot-web` → bot service:   http://dimbybot:3001
#
# If unset in development, the code defaults to http://localhost:{BOT_API_PORT}.
# If unset in production, guild API proxies and `/api/status` bot probe will fail.
#
API_PROXY_TARGET=http://localhost:3001
#
# BOT_API_PORT — used when API_PROXY_TARGET is unset **in development** only
# (defaults to 3001). In Docker, the port is usually embedded in API_PROXY_TARGET.
#
# BOT_API_PORT=3001
#
# BOT_API_PROXY_TIMEOUT_MS — optional; forward timeout for dashboard → bot HTTP (ms).
#
# BOT_API_PROXY_TIMEOUT_MS=

################################################################################
# Verbose logging — dashboard → bot HTTP (`src/web/server/bot-api-verbose.ts`)
################################################################################
#
# BOT_API_VERBOSE=1
# WEB_BOT_API_VERBOSE=1

################################################################################
# Player WebSocket — browser (`src/web/app/api/ws-config`, `src/web/hooks/usePlayerSocket.ts`)
################################################################################
#
# WEBSOCKET_CLIENT_URL — optional `ws:` or `wss:` URL returned to the browser.
#   - Production: prefer **wss://** (plain `ws://` is rejected for this env in production).
#   - When unset in production, the client uses same-origin `wss://{host}/ws` — your
#     reverse proxy must forward `/ws` to the bot’s `BOT_API_PORT` listener.
#
# NEXT_PUBLIC_WS_URL — legacy alias read server-side by `/api/ws-config` (prefer above).
#
# WEBSOCKET_CLIENT_URL=
# NEXT_PUBLIC_WS_URL=
#
# NEXT_PUBLIC_BOT_API_PORT — **development only** fallback in `usePlayerSocket` when
# building `ws://localhost:{port}/ws`. Not used for production same-origin `/ws`.
#
# NEXT_PUBLIC_BOT_API_PORT=3001

################################################################################
# Optional — forwarded to `dimbybot-web` by Compose (same names as bot; not all used by Next)
################################################################################
#
# Root compose passes these for parity with the bot; Better Auth email features may use
# them in the future. Safe to leave empty for dashboard-only sign-in with Discord.
#
# EMAIL_USER=
# EMAIL_PASS=
# FEEDBACK_EMAIL=

################################################################################
# Docker-only — `web-entrypoint.sh` + `docker-compose.dashboard.yml` (not read by `next dev`)
################################################################################
#
# When DATABASE_URL is empty in the container, the entrypoint can synthesize it from:
#   POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB
# …targeting hostname `postgres-db` inside Compose. Prefer setting DATABASE_URL explicitly.
#
# Optional override for synthesized URL (default postgres-db):
# POSTGRES_INTERNAL_HOST=postgres-db
#
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=

################################################################################
# Runtime — container / platform (usually do not set in `.env.local`)
################################################################################
#
# NODE_ENV      — `development` | `production` (Next sets when you run dev/build/start).
# PORT          — HTTP listen port inside `dimbybot-web` (default 3000; see compose WEB_PORT).
# HOSTNAME      — bind address for standalone server (entrypoint default 0.0.0.0).
#
# PORT=3000
