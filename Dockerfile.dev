# Use a recent Node.js LTS version
FROM node:22-alpine

WORKDIR /app

# Optional build-time placeholders for Better Auth / Discord (runtime env from compose).
ARG BETTER_AUTH_URL=http://localhost:3000
ARG CLIENT_ID=000000000000000000
ENV BETTER_AUTH_URL=${BETTER_AUTH_URL}
ENV CLIENT_ID=${CLIENT_ID}

# Install yt-dlp and its dependencies (always latest from pip)
# Also install build tools needed for native Node.js modules
# Use pipx to install yt-dlp to avoid PEP 668 issues (pipx puts binaries in ~/.local/bin, not on PATH).
RUN apk add --no-cache python3 py3-pip ffmpeg build-base autoconf automake libtool g++ pipx su-exec wget \
    && pipx install yt-dlp \
    && export PATH="/root/.local/bin:${PATH}" \
    && YTDLP_BIN="$(command -v yt-dlp)" \
    && test -n "$YTDLP_BIN" && test -x "$YTDLP_BIN" \
    && ln -sf "$YTDLP_BIN" /usr/local/bin/yt-dlp \
    && yt-dlp --version

# Copy package files and install ALL dependencies (including dev)
COPY package.json yarn.lock ./
RUN yarn install && yarn cache clean --all

# Copy the rest of the application code (will be overridden by mounts in dev)
COPY . .

# Dev image skips a production build; bind-mounted source + `yarn dev` (tsc watch + nodemon).

# Copy the entrypoint script outside /app so the dev bind mount
# does not overwrite it with the host copy.
COPY --chmod=755 entrypoint.sh /usr/local/bin/dimbybot-entrypoint.sh

RUN addgroup -S devuser && adduser -S devuser -G devuser \
    && chown -R devuser:devuser /app

# Runtime environment (see Dockerfile in repo root for the full list):
# Autoplay: Spotify API on the bot (compose / .env):
#   LAVALINK_SPOTIFY_CLIENT_ID, LAVALINK_SPOTIFY_CLIENT_SECRET or SPOTIFY_CLIENT_ID, SPOTIFY_CLIENT_SECRET
# MusicBrainz fallback: MUSICBRAINZ_CONTACT or MUSICBRAINZ_CONTACT_URL; MUSICBRAINZ_SIMILAR=off to disable

# Use the same entrypoint as production so dev containers generate
# lavaNodesConfig.js from compose environment before starting nodemon.
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD sh -c 'wget -qO- http://127.0.0.1:${WEB_PORT:-3001}/health || exit 1'

USER devuser

ENTRYPOINT ["/usr/local/bin/dimbybot-entrypoint.sh"]

CMD ["yarn", "dev"]
