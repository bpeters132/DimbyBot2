{
    "name": "dimbybot2",
    "version": "0.2.0",
    "type": "module",
    "description": "A discord bot for friends!",
    "main": "./dist/server.js",
    "scripts": {
        "postinstall": "node scripts/postinstall-prisma.mjs",
        "prebuild": "yarn db:generate",
        "predev": "yarn db:generate",
        "build": "yarn build:bot && yarn build:web",
        "build:bot": "tsc",
        "build:web": "yarn web:install && yarn --cwd src/web build",
        "typecheck": "tsc --noEmit && yarn web:install && yarn --cwd src/web typecheck",
        "lint": "eslint .",
        "test": "tsx --test \"src/**/*.test.ts\"",
        "prisma": "prisma",
        "db:generate": "prisma generate",
        "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
        "start": "node dist/server.js",
        "dev": "tsc && concurrently -k \"tsc -w --preserveWatchOutput\" \"nodemon\"",
        "dev:web": "yarn web:install && yarn --cwd src/web dev",
        "web:install": "yarn --cwd src/web install",
        "docker:dev:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml build",
        "docker:dev:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build -d",
        "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
        "docker:dev:down:volumes": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down -v",
        "docker:dev:rebuild": "yarn docker:dev:down && yarn docker:dev:build && docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
        "docker:dev:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f",
        "deployGlobal": "node ./dist/deploy/deployGlobal.js",
        "destroyGlobal": "node ./dist/deploy/destroyGlobal.js",
        "deployGuild": "node ./dist/deploy/deployGuild.js",
        "destroyGuild": "node ./dist/deploy/destroyGuild.js"
    },
    "license": "MIT",
    "engines": {
        "node": ">=24.0.0"
    },
    "dependencies": {
        "@discordjs/voice": "0.19.2",
        "@opentelemetry/api": "^1.9.1",
        "@prisma/adapter-pg": "^7.6.0",
        "@prisma/client": "^7.6.0",
        "@snazzah/davey": "^0.1.10",
        "better-auth": "^1.6.14",
        "colors": "^1.4.0",
        "date-fns": "^4.1.0",
        "discord.js": "^14.25.1",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "ffmpeg-static": "^5.3.0",
        "lavalink-client": "^2.9.9",
        "opusscript": "^0.1.1",
        "sodium": "^3.0.2",
        "winston": "^3.19.0",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.6",
        "@types/node": "^24.0.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/ws": "^8.18.1",
        "concurrently": "^9.1.2",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "nodemon": "^3.1.14",
        "prettier": "3.8.1",
        "prisma": "^7.6.0",
        "tsx": "^4.20.5",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.26.1"
    },
    "resolutions": {
        "ws": "^8.21.0",
        "undici": "^6.27.0",
        "kysely": "^0.28.17",
        "fast-uri": "^3.1.2",
        "hono": "^4.12.25",
        "qs": "^6.15.2",
        "@hono/node-server": "^1.19.13",
        "lodash": "^4.18.0",
        "shell-quote": "^1.8.4",
        "**/chokidar/**/picomatch": "^2.3.2",
        "**/tinyglobby/**/picomatch": "^4.0.4"
    },
    "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
    "nodemonConfig": {
        "ignore": [
            "storage/*",
            "logs/*"
        ],
        "watch": [
            "dist"
        ],
        "ext": "js,json",
        "delay": 1000,
        "legacyWatch": true,
        "watchOptions": {
            "usePolling": true,
            "interval": 1000
        },
        "exec": "node dist/server.js"
    }
}
