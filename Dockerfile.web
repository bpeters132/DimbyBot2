# Next.js dashboard only — standalone output (separate from the bot image).
FROM node:22-alpine3.22 AS builder

WORKDIR /app

# Root lockfile installs bot deps (e.g. `sodium` for @discordjs/voice); that package builds libsodium and needs a toolchain.
RUN apk add --no-cache \
    build-base \
    autoconf \
    automake \
    libtool \
    python3

COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile

COPY . .
RUN yarn db:generate && yarn web:install && yarn --cwd src/web build

FROM node:22-alpine3.22

WORKDIR /app

RUN apk add --no-cache wget dos2unix \
    && addgroup -S webuser && adduser -S webuser -G webuser

COPY web-entrypoint.sh /app/web-entrypoint.sh
RUN dos2unix /app/web-entrypoint.sh \
    && chmod +x /app/web-entrypoint.sh \
    && apk del dos2unix

COPY --from=builder /app/src/web/.next/standalone /app
COPY --from=builder /app/src/web/.next/static /app/.next/static

RUN chown -R webuser:webuser /app

USER webuser

ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

# Liveness only: `/api/status` probes DB + bot and can exceed Docker's 5s probe timeout.
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD wget --timeout=5 --tries=1 -qO- "http://127.0.0.1:${PORT:-3000}/api/health" >/dev/null 2>&1 || exit 1

ENTRYPOINT ["/app/web-entrypoint.sh"]
