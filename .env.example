###########################
# .env file used for local development (and as a template for required keys).
# In production (e.g. GitHub Actions deploy), equivalent values come from CI secrets / server env.
###########################

# Discord Bot Credentials
BOT_TOKEN=
CLIENT_ID=
# Optional: For development/testing guild commands
GUILD_ID=
OWNER_ID=

# Bot Settings
# YES/NO
DEV_MODE=
# set to debug for more verbose logging
LOG_LEVEL=
WEB_ENABLED=true
# Bot HTTP (when WEB_ENABLED=true): Express `/api/guilds/*`, `/ws`, `/health` only — no Next.js inside the bot container.
# The dashboard is still a normal Next.js app under `src/` (`yarn dev:web`, `yarn build:web`); run or deploy it as its own process/service.
# WEB_PORT configures the bot/Express listener (default 3001). Next dashboard runs on 3000.
WEB_PORT=3001
# API_PROXY_TARGET configures which bot API origin the Next dashboard proxies to.
# Default local bot API: http://localhost:3001
# Set this when using a non-default proxy target (for example cross-origin or remote bot deployments).
API_PROXY_TARGET=http://localhost:3001
# Verbose logging for dashboard → bot HTTP (Next terminal + bot terminal). No cookies or bodies logged.
# BOT_API_VERBOSE=1
# Alias (either works on Next or bot): WEB_BOT_API_VERBOSE=1
# Better Auth: one DB + secret; two HTTP entrypoints (see src/web/lib/auth-base-config.ts).
# BETTER_AUTH_URL = public URL of the Next dashboard (OAuth callback + cookie issuer), e.g. http://localhost:3000
# The bot container serves plain Express /api/guilds + /ws only — it uses auth-node (no Next) but reads the same sessions.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# WebSocket: dashboard and bot are different origins (different ports). Session cookies are not sent to the bot WS.
# Next serves GET /api/ws-ticket (signed with BETTER_AUTH_SECRET); the client appends ?ticket=… to ws://…/ws and the bot verifies it.
# Optional absolute ws/wss URL for the player socket (read at runtime via GET /api/ws-config). When unset, the browser uses same-origin /ws (dev: port 3000 → ws on :3001).
# WEBSOCKET_CLIENT_URL=wss://bot.example.com/ws
DISCORD_CLIENT_SECRET=

# Database (Prisma / PostgreSQL)
POSTGRES_DB=bot_db
POSTGRES_USER=bot_user
POSTGRES_PASSWORD=
# DATABASE_URL is assembled by docker-compose.yml for the dimbybot container.
# If you run the bot with `yarn dev` on the host while Postgres is in Docker (port 5432 published),
# set DATABASE_URL explicitly — it must not use the hostname `postgres-db` (that only resolves inside Compose):
# DATABASE_URL=postgresql://bot_user:YOUR_PASSWORD@localhost:5432/bot_db
#
# Avoid `docker compose down -v` / `yarn docker:dev:down:volumes` unless you intend to wipe the database volume.

# Other Credentials (if used by bot features)
EMAIL_USER=
EMAIL_PASS=
# Inbox for the disabled /suggest command (nodemailer To: address), if you enable it
FEEDBACK_EMAIL=

# Lavalink Configuration
# LAVALINK_HOST should match the Lavalink service name in docker-compose.yml (e.g. lavalink).
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
# LAVALINK_PASSWORD must match Lavalink application.yml; change the default in production.
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_NODE_ID=mainNode
# LAVALINK_SECURE: set true when the Lavalink connection uses TLS/wss.
LAVALINK_SECURE=false

# Lavalink Optional Features (YouTube POT - see https://github.com/iv-org/youtube-trusted-session-generator)
LAVALINK_YOUTUBE_POT_TOKEN=
LAVALINK_YOUTUBE_POT_VISITORDATA=

# Lavalink Optional Features (Spotify - requires client ID/secret).
# LAVALINK_SPOTIFY_* configures Lavalink’s Spotify plugin (loading Spotify URLs/playlists).
# These also feed Spotify-first catalog autoplay (related artists + top tracks); MusicBrainz fills gaps when the bot cannot use Spotify.
# Set SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET only when this Node process calls the Spotify Web API directly (e.g. similar-tracks / catalog autoplay when Lavalink’s Spotify plugin is off or unavailable). Lavalink uses LAVALINK_SPOTIFY_CLIENT_ID / LAVALINK_SPOTIFY_CLIENT_SECRET for resolving Spotify URLs in the player; those env vars are separate from SPOTIFY_*.
LAVALINK_SPOTIFY_ALBUM_LOAD_LIMIT=6
LAVALINK_SPOTIFY_CLIENT_ID=
LAVALINK_SPOTIFY_CLIENT_SECRET=
LAVALINK_SPOTIFY_COUNTRY_CODE=US
LAVALINK_SPOTIFY_ENABLED=true
LAVALINK_SPOTIFY_PLAYLIST_LOAD_LIMIT=6
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Autoplay: MusicBrainz fallback when Spotify returns nothing (https://musicbrainz.org/doc/MusicBrainz_API — ~1 req/s, User-Agent required).
# Requires MUSICBRAINZ_CONTACT or MUSICBRAINZ_CONTACT_URL. docker-compose defaults MUSICBRAINZ_SIMILAR to off — set to on (or true) to enable when contact is set.
# MUSICBRAINZ_CONTACT=you@example.com
# MUSICBRAINZ_CONTACT_URL=https://your-site.example
# MUSICBRAINZ_SIMILAR=on
